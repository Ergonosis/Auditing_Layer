# Plaid (PLAID_ACCESS_TOKEN is the credential the adapter checks at runtime)
PLAID_ACCESS_TOKEN=your_plaid_access_token

# Microsoft Graph
MSGRAPH_CLIENT_ID=your_msgraph_client_id
MSGRAPH_CLIENT_SECRET=your_msgraph_client_secret
MSGRAPH_TENANT_ID=your_msgraph_tenant_id  # required by ms_graph_email_client, not checked directly here

# Databricks (not yet provisioned — leave blank and set UNIFICATION_SECURE_STORAGE_REQUIRED=false for dev)
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_HTTP_PATH=
DATABRICKS_CATALOG=ergonosis
DATABRICKS_SCHEMA=unification

# Security mode — set true in prod to prevent fallback to local SQLite when Databricks is unavailable
UNIFICATION_SECURE_STORAGE_REQUIRED=false

# Ingestion identity (overrides unification_config.yaml ingestion section)
UNIFICATION_PLAID_ACCOUNT_ID=
UNIFICATION_USER_EMAIL=

# Ingestion stub mode (set true to use fixture data without real credentials)
STUB_INGESTION=true

# Prometheus metrics endpoint (leave empty to disable; set e.g. 8000 to expose /metrics)
METRICS_PORT=

# Logging
LOG_LEVEL=INFO
