# =============================================================================
# Copy this file to .env and fill in the required values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider — "anthropic" (default, SOC 2 compliant) or "openai"
# -----------------------------------------------------------------------------

LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Optional model overrides (provider.py constants used by default)
# DEFAULT_LLM_MODEL=claude-haiku-4-5-20251001
# SMART_LLM_MODEL=claude-sonnet-4-6


# -----------------------------------------------------------------------------
# Not needed for the demo (demo uses in-memory state, not Redis or Databricks)
# -----------------------------------------------------------------------------

DATABRICKS_HOST=your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi_xxxxx
DATABRICKS_WAREHOUSE_ID=warehouse_id
DATABRICKS_CATALOG=auditing_catalog

REDIS_HOST=localhost:6379
REDIS_DB=0
STATE_BACKEND=redis

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_LEVEL=INFO
ENVIRONMENT=development
